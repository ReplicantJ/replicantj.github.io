# Copy to .env.local for local overrides (not committed).

# Future API origin, no trailing slash (e.g. https://api.example.com)
VITE_API_BASE_URL=

# Vite asset base. Use "/" for custom domains or user.github.io root.
# For project Pages URLs (user.github.io/repo-name/), set to "/repo-name/"
VITE_BASE_PATH=/
